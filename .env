# Backend Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (SQLite for dev, easily switchable to PostgreSQL)
DATABASE_URL="file:./dev.db"

# Security and Auth Config
JWT_SECRET="crm-secret-access-token-key-123456789-prod-crm"
JWT_REFRESH_SECRET="crm-secret-refresh-token-key-123456789-prod-crm"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# CORS configuration
ALLOWED_ORIGINS="http://localhost:5173"

# Upload Folder Configuration
UPLOAD_DIR="./uploads"
